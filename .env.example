# SENTINEL Configuration
# Copy to .env and fill in your values

SENTINEL_DEBUG=false
SENTINEL_CAMERA_INDEX=0
SENTINEL_SENSITIVITY=medium

# Push Notifications (ntfy.sh)
SENTINEL_NTFY_TOPIC=

# MQTT Broker (for IoT devices)
SENTINEL_MQTT_BROKER_HOST=localhost
SENTINEL_MQTT_BROKER_PORT=1883
SENTINEL_MQTT_USERNAME=
SENTINEL_MQTT_PASSWORD=

# Home Assistant
SENTINEL_HA_URL=
SENTINEL_HA_TOKEN=

# IFTTT Webhooks
SENTINEL_IFTTT_KEY=

# Telegram Bot
SENTINEL_TELEGRAM_BOT_TOKEN=
SENTINEL_TELEGRAM_CHAT_ID=
